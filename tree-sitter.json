{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "delphi",
      "camelcase": "Delphi",
      "title": "Delphi",
      "scope": "source.delphi",
      "file-types": [
        "delphi"
      ],
      "injection-regex": "^delphi$",
      "class-name": "TreeSitterDelphi"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Delphi grammar for tree-sitter",
    "authors": [
      {
        "name": "Medhi SAM",
        "email": "sammedhi2@hotmail.fr",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-delphi",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}